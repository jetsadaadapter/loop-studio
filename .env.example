# ─── Google OAuth (via Centralized MCP) ─────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Domain restriction ──────────────────────────────────────────────────────
ALLOWED_EMAIL_DOMAIN=@email.example.com

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_STORE_API_BASE_URL=http://library-api.internal/api

# Optional: override API base URL for server-side fetches only (e.g. internal network).
# If unset, falls back to NEXT_PUBLIC_STORE_API_BASE_URL.
# SERVER_API_BASE_URL=http://library-api.internal/api

# ─── Zero Trust ──────────────────────────────────────────────────────────────

# Optional: set when callback path is not /callback
NEXT_PUBLIC_ZT_CALLBACK_PATH=/callback

# Keep disabled in production unless actively troubleshooting
NEXT_PUBLIC_ZT_DEBUG_CALLBACK=false
