# ─── Google OAuth (via Centralized MCP) ─────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Domain restriction ──────────────────────────────────────────────────────
ALLOWED_EMAIL_DOMAIN=@email.example.com

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_STORE_API_BASE_URL=http://library-api.internal/api

# Optional: override API base URL for server-side fetches only (e.g. internal network).
# If unset, falls back to NEXT_PUBLIC_STORE_API_BASE_URL.
# SERVER_API_BASE_URL=http://library-api.internal/api

# ─── Zero Trust ──────────────────────────────────────────────────────────────

# Optional: set when callback path is not /callback
NEXT_PUBLIC_ZT_CALLBACK_PATH=/callback

# Keep disabled in production unless actively troubleshooting
NEXT_PUBLIC_ZT_DEBUG_CALLBACK=false

# ─── Loop DevStudio (AI chat) ────────────────────────────────────────────────
# Optional: server-side Anthropic key so the Loop DevStudio chat replies live
# in-app without each user pasting their own key. When unset (and the user has
# not saved a key in the AI Team Manager), chat falls back to the IDE bridge.
# A per-user key (Anthropic sk-ant-… or Google AI Studio AIza…) wins over these.
# Provider is auto-detected from the key prefix.
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza... or AQ....  # free tier via Google AI Studio (aistudio.google.com)
# LOOP_GEMINI_MODEL=gemini-2.5-flash   # optional: override the Gemini model
